# Server
PORT=5000
NODE_ENV=development
BASE_URL=http://localhost:5000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/hrms_db


# JWT
JWT_SECRET=change_this_super_secret_key
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change_this_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=7d

# Office Geo-fence (for GPS attendance)
OFFICE_LAT=25.3176
OFFICE_LNG=82.9739
OFFICE_RADIUS_METERS=200

# File uploads
MAX_FILE_SIZE_MB=10
